{
  "name": "sovara",
  "displayName": "Sovara",
  "description": "Inspect, edit, and replay agent workflows without leaving VS Code.",
  "repository": {
    "type": "git",
    "url": "https://github.com/SovaraLabs/sovara.git"
  },
  "homepage": "https://sovara-labs.com",
  "bugs": {
    "url": "https://github.com/SovaraLabs/sovara/issues",
    "email": "support@sovara-labs.com"
  },
  "version": "0.2.0",
  "publisher": "SovaraLabs",
  "license": "Apache-2.0",
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Visualization",
    "Machine Learning"
  ],
  "keywords": [
    "agent",
    "agents",
    "agentic",
    "workflow",
    "workflows",
    "llm",
    "prompt",
    "trace",
    "graph",
    "visualization",
    "debugging",
    "observability",
    "optimization",
    "optimize"
  ],
  "galleryBanner": {
    "color": "#E7F1E6",
    "theme": "dark"
  },
  "markdown": "github",
  "pricing": "Free",
  "qna": false,
  "preview": true,
  "author": {
    "name": "Sovara Labs"
  },
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": false
    }
  },
  "activationEvents": [
    "onStartupFinished",
    "onWebviewPanel:sovara.graphTab"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "sovara.showGraph",
        "title": "Open Sidebar",
        "category": "Sovara"
      }
    ],
    "configuration": {
      "title": "Sovara",
      "properties": {
        "sovara.pythonServerHost": {
          "type": "string",
          "default": "127.0.0.1",
          "description": "Host of the Python development server"
        },
        "sovara.pythonServerPort": {
          "type": "number",
          "default": 5959,
          "description": "Port of the Python development server"
        }
      }
    },
    "views": {
      "sovara-sidebar": [
        {
          "type": "webview",
          "id": "sovara.graphView",
          "name": "Sovara",
          "icon": "$(graph)",
          "contextualTitle": "Sovara",
          "retainContextWhenHidden": true
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "sovara-sidebar",
          "title": "Sovara",
          "icon": "$(type-hierarchy)"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package && rm -f dist/*.map",
    "compile": "webpack",
    "build": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.5",
    "@types/node": "^16.18.126",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@types/vscode": "^1.74.0",
    "@types/ws": "^8.5.10",
    "copy-webpack-plugin": "^13.0.1",
    "css-loader": "^6.11.0",
    "style-loader": "^3.3.4",
    "ts-loader": "^9.5.2",
    "typescript": "^5.9.2",
    "webpack": "^5.99.9",
    "webpack-cli": "^5.1.4"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.39.0",
    "@tisoap/react-flow-smart-edge": "^2.0.0",
    "@vscode/codicons": "^0.0.42",
    "elkjs": "^0.8.2",
    "js-yaml": "^4.1.0",
    "lossless-json": "^4.0.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-pdf": "^10.4.1",
    "react-syntax-highlighter": "^16.1.1",
    "reactflow": "^11.10.0",
    "ws": "^8.14.2"
  }
}
